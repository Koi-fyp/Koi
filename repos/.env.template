# =============================================================================
# KOI Project - Environment Variables Template
# =============================================================================
# IMPORTANT: This is a template file. Create a .env.local file with actual values
# NEVER commit actual API keys or secrets to version control
# =============================================================================

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=koi-companion-fyp
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=koi-companion-fyp.firebaseapp.com
FIREBASE_DATABASE_URL=https://koi-companion-fyp.firebasedatabase.app
FIREBASE_STORAGE_BUCKET=koi-companion-fyp.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin SDK (backend only)
# Generate from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY=path_to_service_account_key.json
FIREBASE_ADMIN_UID_PREFIX=admin

# =============================================================================
# GOOGLE CLOUD - GEMINI API
# =============================================================================
# Get from Google Cloud Console > APIs & Services > Credentials > Create API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_RATE_LIMIT=60  # requests per minute
GEMINI_SAFETY_LEVEL=BLOCK_MOST_HARMFUL  # BLOCK_NONE, BLOCK_SOME_HARMFUL, BLOCK_MOST_HARMFUL, BLOCK_ALL

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # Backend only

# Database connection (for direct access from backend)
SUPABASE_DB_HOST=your-project.db.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_database_password_here

# Connection pooling (PgBouncer)
SUPABASE_POOL_MODE=transaction
SUPABASE_MAX_CONNECTIONS=5
SUPABASE_POOL_SIZE=10

# =============================================================================
# EMAIL SERVICE CONFIGURATION
# =============================================================================
# Choose either SendGrid OR AWS SES (not both)

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@koi-companion.com
SENDGRID_FROM_NAME=KOI Companion

# OR AWS SES Configuration
AWS_SES_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SES_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@koi-companion.com

# Email templates
EMAIL_TEMPLATE_PATH=./email_templates
EMAIL_VERIFICATION_TEMPLATE=verification.html
EMAIL_CLINICAL_REPORT_TEMPLATE=clinical_report.html
EMAIL_PASSWORD_RESET_TEMPLATE=password_reset.html

# =============================================================================
# VERCEL DEPLOYMENT
# =============================================================================
# Auto-configured by Vercel deployment
VERCEL_URL=https://koi-web.vercel.app
NEXT_PUBLIC_API_URL=https://api.koi-companion.com
NEXT_PUBLIC_FIREBASE_CONFIG={json_config_here}

# Build-time variables
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_APP_VERSION=0.1.0

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment (development, staging, production)
NODE_ENV=development
ENVIRONMENT=development
DEBUG=false

# Application URLs
APP_NAME=KOI Companion
APP_DESCRIPTION=Medical diagnostics companion powered by AI
APP_URL=https://koi-companion.com
API_BASE_URL=http://localhost:5000  # For local development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://koi-companion.com

# Session Configuration
SESSION_SECRET=your_session_secret_key_here
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
# Sentry Error Tracking (optional)
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENABLED=false

# Google Analytics
NEXT_PUBLIC_GA_ID=your_google_analytics_id
NEXT_PUBLIC_GA_ENABLED=false

# Custom analytics
ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=10
ANALYTICS_BATCH_INTERVAL=5000  # milliseconds

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=15 * 60 * 1000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# HTTPS & SSL
HTTPS_ONLY=true
SSL_REDIRECT=true

# Security Headers
SECURITY_HEADERS_ENABLED=true
CORS_CREDENTIALS=true

# Password Security
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_GEMINI_ANALYSIS=true
FEATURE_DIAGNOSTIC_REPORTS=true
FEATURE_USER_PROFILES=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_OFFLINE_MODE=false  # Development feature

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Local Firebase Emulator Suite
USE_FIRESTORE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Local Supabase Emulator (if using)
USE_SUPABASE_LOCAL=false
SUPABASE_LOCAL_URL=http://localhost:54321

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json, simple

# =============================================================================
# CI/CD CONFIGURATION
# =============================================================================
# GitHub Actions
CI=true
CI_COMMIT_SHA=auto
CI_BRANCH=auto

# Deployment
DEPLOY_KEY=your_deployment_key_here
DEPLOY_WEBHOOK=your_webhook_url_here

# =============================================================================
# SECURITY NOTES
# =============================================================================
# ✓ Use .env.local for development (Git-ignored)
# ✓ Use environment variables in production (never .env files)
# ✓ Rotate API keys quarterly
# ✓ Use separate keys for dev, staging, production
# ✓ Enable MFA on all service accounts
# ✓ Monitor API usage for unexpected spikes
# ✓ Use principle of least privilege for all API keys
# =============================================================================
