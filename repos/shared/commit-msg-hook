#!/bin/bash
# Commit Message Validator - Enforces Conventional Commits format
# This script validates that commit messages follow the Conventional Commits standard

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Remove leading/trailing whitespace
commit_msg=$(echo "$commit_msg" | xargs)

# Skip validation for merge commits
if [[ "$commit_msg" == Merge* ]]; then
    exit 0
fi

# Conventional Commits regex pattern
# Format: <type>(<scope>): <subject>
# Example: feat(auth): add OAuth login
conventional_commit_regex="^(feat|fix|docs|style|refactor|test|chore|ci|perf|build|revert)(\([a-z0-9\-]+\))?: .{1,100}"

if ! echo "$commit_msg" | grep -qE "$conventional_commit_regex"; then
    {
        echo ""
        echo "❌ ERROR: Commit message does not follow Conventional Commits format!"
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "FORMAT:"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "<type>(<scope>): <subject>"
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "TYPES:"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  feat     - A new feature"
        echo "  fix      - A bug fix"
        echo "  docs     - Documentation only changes"
        echo "  style    - Changes that do not affect code meaning (formatting, semicolons, etc)"
        echo "  refactor - Code change that neither fixes a bug nor adds a feature"
        echo "  test     - Adding missing tests or correcting existing tests"
        echo "  chore    - Changes to build process, dependencies, or tooling"
        echo "  ci       - Changes to CI/CD configuration"
        echo "  perf     - Code change that improves performance"
        echo "  build    - Changes that affect the build system or dependencies"
        echo "  revert   - Reverts a previous commit"
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "EXAMPLES:"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "✓ feat(auth): add OAuth login"
        echo "✓ fix(api): resolve timeout issue"
        echo "✓ docs: update README with setup instructions"
        echo "✓ style(ui): format button component"
        echo "✓ refactor(db): simplify connection logic"
        echo "✓ test(auth): add login validation tests"
        echo "✓ chore(deps): update dependencies"
        echo ""
        echo "YOUR COMMIT MESSAGE:"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "$commit_msg"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
    } >&2
    exit 1
fi

exit 0
