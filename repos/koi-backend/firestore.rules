rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isAuth(userId);
    }

    // conversationId == userId (1:1 conversation model per user)
    match /conversations/{userId}/messages/{messageId} {
      allow read, write: if isAuth(userId);
    }

    match /mood_entries/{userId}/entries/{entryId} {
      allow read, write: if isAuth(userId);
    }

    match /wellness_progress/{userId} {
      allow read, write: if isAuth(userId);
    }

    match /tasks/{userId}/items/{taskId} {
      allow read, write: if isAuth(userId);
    }

    // crisis_events_local: device-only, never synced to Firestore

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
